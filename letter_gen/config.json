{
  "tenth_marksheet": {
    "template": "template/Marksheet_Verification_TEMPLATE.docx",
    "source": "tenth_marksheet",
    "is_list": false,
    "required": ["student_name", "school_name"],
    "output_pattern": "{student_name}_10TH_Verification.docx",
    "fields": {
      "{{ref_no}}": "registration_number",
      "{{letter_date}}": "__today__",
      "{{school_name}}": "school_name",
      "{{school_address}}": "__address__:school_address",
      "{{student_name}}": "student_name|upper",
      "{{father_name}}": "father_name|upper",
      "{{mother_name}}": "mother_name|upper",
      "{{date_of_birth}}": "date_of_birth",
      "{{examination_passed}}": "examination_passed|upper",
      "{{roll_number}}": "roll_number",
      "{{grade_digit}}": "__const__:0"
    }
  },

  "twelfth_marksheet": {
    "template": "template/Marksheet_Verification_TEMPLATE.docx",
    "source": "twelfth_marksheet",
    "is_list": false,
    "required": ["student_name", "school_name"],
    "output_pattern": "{student_name}_12TH_Verification.docx",
    "fields": {
      "{{ref_no}}": "registration_number",
      "{{letter_date}}": "__today__",
      "{{school_name}}": "school_name",
      "{{school_address}}": "__address__:school_address",
      "{{student_name}}": "student_name|upper",
      "{{father_name}}": "father_name|upper",
      "{{mother_name}}": "mother_name|upper",
      "{{date_of_birth}}": "date_of_birth",
      "{{examination_passed}}": "examination_passed|upper",
      "{{roll_number}}": "roll_number",
      "{{grade_digit}}": "__const__:2"
    }
  },

  "transfer_certificate": {
    "template": "template/TC_Verification_TEMPLATE.docx",
    "source": "transfer_certificate",
    "is_list": false,
    "required": ["candidate_name", "school_name"],
    "output_pattern": "{candidate_name}_{school_name}_Transfer_Certificate_Verification.docx",
    "fields": {
      "{{case_id}}": "tc_number",
      "{{letter_date}}": "__today__",
      "{{candidate_name}}": "candidate_name|upper",
      "{{father_name}}": "father_name|upper",
      "{{mother_name}}": "mother_name|upper",
      "{{date_of_birth}}": "date_of_birth",
      "{{date_of_leaving}}": "date_of_leaving",
      "{{school_name}}": "school_name",
      "{{school_address}}": "__address__:school_address",
      "{{tc_number}}": "tc_number"
    }
  },

  "internship_certificate": {
    "template": "template/Internship_Verification_TEMPLATE.docx",
    "source": "internship_certificate.certificate",
    "is_list": true,
    "required": ["candidate_name", "company_name"],
    "output_pattern": "{candidate_name}_{company_name}_Internship_Verification.docx",
    "fields": {
      "{{candidate_name}}": "candidate_name|upper",
      "{{company_name}}": "company_name",
      "{{training_location}}": "__address__:training_location",
      "{{training_period}}": "training_period",
      "{{training_program}}": "training_program",
      "{{nature_of_training}}": "nature_of_training"
    }
  },

  "marriage_certificate": {
    "template": "template/Marriage_Certificate_Verification_TEMPLATE.docx",
    "source": "marriage_certificate",
    "is_list": false,
    "required": ["spouse1_name", "spouse2_name", "certificate_number", "registrar_office"],
    "output_pattern": "{spouse1_name}_{spouse2_name}_Marriage_Certificate_Verification.docx",
    "fields": {
      "{{case_id}}": "certificate_number",
      "{{case}}": "certificate_number",
      "{{letter_date}}": "__today__",
      "{{registrar_office}}": "registrar_office",
      "{{office_address}}": "__address__:office_address",
      "{{date_of_marriage}}": "date_of_marriage",
      "{{place_of_marriage}}": "place_of_marriage",
      "{{certificate_number}}": "certificate_number",
      "{{spouse1_name}}": "spouse1_name|upper",
      "{{spouse2_name}}": "spouse2_name|upper"
    }
  },
  "employment_certificate": {
    "template": "template/Employment_Verification_TEMPLATE.docx",
    "source": "employment_certificate.certificates",
    "is_list": true,
    "required": ["candidate_name", "company_name"],
    "output_pattern": "{candidate_name}_{company_name}_Employment_Verification.docx",
    "fields": {
      "{{ref_no}}": "employee_id",
      "{{letter_date}}": "__today__",
      "{{candidate_name}}": "candidate_name|upper",
      "{{company_name}}": "company_name",
      "{{company_address}}": "__address__:company_address",
      "{{company_telephone}}": "company_telephone",
      "{{period_of_employment}}": "period_of_employment",
      "{{designation}}": "designation",
      "{{authority_name}}": "authority_name"
    }
  }
}
